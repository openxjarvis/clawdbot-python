# OpenClaw Python - Environment Variables
# ==========================================
# Copy this file to `.env` (for local runs), OR to `~/.openclaw/.env` (for daemon).
# Fill in values for providers you use. NEVER commit .env with real keys!
#
# Environment Variable Loading Priority (highest → lowest):
#   1. System process.env (already-set environment variables — never overridden)
#   2. CWD .env (current working directory — project-level, developer convenience)
#   3. ~/.openclaw/.env (global user-level — daemon and CLI fallback)
#   4. openclaw.json env block (configuration file — last resort)
#
# Note: Keys stored here act as a fallback. You can also set keys during onboarding
# (stored in ~/.openclaw/agents/main/agent/auth-profiles.json) or via system env vars.

# ==========================================
# LLM API Keys (至少配置一个)
# ==========================================

# Anthropic Claude (推荐)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI GPT
OPENAI_API_KEY=sk-your-key-here

# Google Gemini
GOOGLE_API_KEY=your-google-key-here
# GEMINI_API_KEY=your-gemini-key-here  # Alternative

# Moonshot AI (Kimi)
MOONSHOT_API_KEY=your-moonshot-key-here
# KIMI_CODE_API_KEY=your-kimi-code-key-here  # For Kimi Code subscription

# Kimi Coding (separate from Moonshot)
KIMI_API_KEY=your-kimi-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key-here

# Groq (快速推理)
GROQ_API_KEY=your-groq-key-here

# xAI (Grok)
XAI_API_KEY=your-xai-key-here

# Mistral AI
MISTRAL_API_KEY=your-mistral-key-here

# Together AI
TOGETHER_API_KEY=your-together-key-here

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key-here

# HuggingFace
HUGGINGFACE_API_KEY=your-hf-key-here
# HF_TOKEN=your-hf-token-here  # Alternative

# Cerebras
CEREBRAS_API_KEY=your-cerebras-key-here

# ── Chinese AI Providers ──

# Zhipu AI (GLM / Z.AI)
ZAI_API_KEY=your-zai-key-here
# ZHIPU_API_KEY=your-zhipu-key-here  # Alternative

# MiniMax
MINIMAX_API_KEY=your-minimax-key-here
MINIMAX_CN_API_KEY=your-minimax-cn-key-here

# Qwen (Alibaba DashScope)
DASHSCOPE_API_KEY=your-dashscope-key-here
# QWEN_API_KEY=your-qwen-key-here  # Alternative

# AWS Bedrock
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# ==========================================
# 频道配置 (Channel Tokens)
# ==========================================

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord
DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_APP_TOKEN=xapp-your-app-token

# ==========================================
# Gateway 配置
# ==========================================

# Gateway 端口
OPENCLAW_GATEWAY_PORT=18789

# Web UI 端口
OPENCLAW_WEB_PORT=8080

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
OPENCLAW_LOG_LEVEL=INFO

# 环境 (development, production)
OPENCLAW_ENV=development

# ==========================================
# OpenTelemetry 配置 (可选)
# ==========================================

# OTLP 导出端点 (用于 metrics/traces/logs)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# 启用 OpenTelemetry
OPENCLAW_OTEL_ENABLED=false

# ==========================================
# 工具配置 (可选)
# ==========================================

# Tavily 搜索 API
TAVILY_API_KEY=your-tavily-key

# Serper 搜索 API
SERPER_API_KEY=your-serper-key

# Browserless (浏览器服务)
BROWSERLESS_TOKEN=your-browserless-token

# ==========================================
# 安全配置
# ==========================================

# 允许的来源 (CORS)
OPENCLAW_ALLOWED_ORIGINS=http://localhost:8080

# 最大会话数
OPENCLAW_MAX_SESSIONS=100

# 会话超时 (秒)
OPENCLAW_SESSION_TIMEOUT=3600

# ==========================================
# 沙箱配置
# ==========================================

# 启用 Docker 沙箱
OPENCLAW_SANDBOX_ENABLED=true

# Docker 沙箱镜像
OPENCLAW_SANDBOX_IMAGE=python:3.12-slim

# ==========================================
# 其他配置
# ==========================================

# 工作空间目录
OPENCLAW_WORKSPACE=~/.openclaw/workspace

# 配置文件路径
OPENCLAW_CONFIG=~/.openclaw/config.json5

# 🔐 安全提醒:
# 1. 永远不要提交包含真实 API keys 的 .env 文件
# 2. 使用强密钥，定期轮换
# 3. 生产环境使用密钥管理服务 (AWS Secrets Manager, etc.)
# 4. 限制 API key 权限到最小必需
